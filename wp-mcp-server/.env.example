# ============================================
# WordPress MCP Server - Environment Variables
# ============================================
# Set these in your .mcp.json "env" block (recommended)
# or copy this file to .env and fill in your values.

# --- REQUIRED: WordPress Connection ---
WP_SITE_URL=https://your-site.com
WP_USERNAME=your_username
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# --- OPTIONAL: Server Identity ---
# MCP_SERVER_NAME=my-site-wp
# MCP_SERVER_VERSION=1.0.0

# --- OPTIONAL: AI Content Generation (Claude) ---
# Enables: generate_travel_post, generate_destination_description,
#          generate_seo_content, generate_image_prompt
# ANTHROPIC_API_KEY=sk-ant-...
# AI_MODEL=claude-sonnet-4-20250514
# AI_MAX_TOKENS=4096

# --- OPTIONAL: AI Image Generation (Google Imagen) ---
# Enables: generate_destination_image
# Get a key from https://aistudio.google.com/apikey
# GEMINI_API_KEY=your_gemini_key
# IMAGE_MODEL=imagen-4.0-generate-001
# IMAGE_ASPECT_RATIO=16:9

# --- OPTIONAL: Kaira Image Generation (Replicate) ---
# Enables: generate_kaira_image, list_kaira_presets
# Only useful if you've trained a LoRA model on Replicate.
# REPLICATE_API_TOKEN=r8_...
# KAIRA_MODEL_VERSION=your-trained-model-version-hash
# KAIRA_TRIGGER_TOKEN=KAIRA

# --- OPTIONAL: Content Voice / Prompts ---
# Path to a custom prompts file (ES module exporting prompt constants)
# If not set, uses the default prompts in prompts/system-prompts.js
# CUSTOM_PROMPTS_PATH=/path/to/my-prompts.js
